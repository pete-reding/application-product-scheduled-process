# ─────────────────────────────────────────────
#  Product Normalizer — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# MotherDuck authentication token
# Obtain from: https://app.motherduck.com/settings/tokens
MOTHERDUCK_TOKEN=your_motherduck_token_here

# --- Database identifiers (defaults shown) ---
# Read-only source database (agmri share)
AGMRI_DB=agmri

# Read-only product catalog share
CATALOG_DB=product_normalization_table

# Writable output database
WRITE_DB=IntelinairAnalyzeDB

# Schema inside WRITE_DB for all pipeline tables
PIPELINE_SCHEMA=product_normalization

# --- Matching thresholds ---
FUZZY_THRESHOLD=72          # Minimum token-set-ratio score (0-100)
MIN_TOKEN_LENGTH=2          # Ignore tokens shorter than this

# --- Google Drive export ---
# Folder ID from the Drive URL when you open the target folder
GDRIVE_FOLDER_ID=your_google_drive_folder_id

# --- Notifications ---
# macOS notification sound (Glass, Ping, Basso, Purr, etc.)
MACOS_SOUND=Glass

# --- Logging ---
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs
